  <property name="windowTitle">
   <string>Африканская саванна — симуляция</string>
  </property>
  <property name="styleSheet">
   <string notr="true">
/* Общий фон окна — песок */
QMainWindow {
    background-color: #d2b48c;
}

/* Кнопки в стиле дерева/кожи */
QPushButton {
    background-color: #8b5a2b;
    border: 2px solid #c2a15b;
    border-radius: 8px;
    padding: 6px 12px;
    color: #fff0e0;
    font-weight: bold;
    font-size: 12px;
}
QPushButton:hover {
    background-color: #a5713c;
    border-color: #e0b87a;
}
QPushButton:pressed {
    background-color: #6b3e1a;
}

/* Область карты — светлый песок, рамка под дерево */
QGraphicsView {
    background-color: #f5e6d3;
    border: 3px solid #b97f3a;
    border-radius: 12px;
}

/* Группы информации и лога */
QGroupBox {
    color: #4e2a1a;
    border: 2px solid #b97f3a;
    border-radius: 8px;
    margin-top: 0.5ex;
    font-weight: bold;
    background-color: rgba(210, 180, 140, 0.5);
}
QGroupBox::title {
    subcontrol-origin: margin;
    left: 10px;
    padding: 0 5px;
    color: #4e2a1a;
    background-color: #f5e6d3;
}

/* Метки внутри групп */
QLabel {
    color: #3b2a1f;
    font-size: 12px;
}

/* Поле лога */
QTextEdit {
    background-color: #4a2e1e;
    color: #f5e6d3;
    border: 1px solid #b97f3a;
    font-family: 'Courier New', monospace;
    font-size: 11px;
}

/* Слайдер скорости */
QSlider::groove:horizontal {
    height: 6px;
    background: #c2a15b;
    border-radius: 3px;
}
QSlider::handle:horizontal {
    background: #8b5a2b;
    width: 14px;
    margin: -4px 0;
    border-radius: 7px;
}
QSlider::handle:horizontal:hover {
    background: #a5713c;
}
   </string>
